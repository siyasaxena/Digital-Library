<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bookz</title>
    <link rel="stylesheet" href="/style.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    
  </head>
  <body>
    <h1>Welcome Back !!</h1>
    <div class="main_book">
      <% for(book of books){ %>
        <div class="card mb-3 ">
          <img src="<%= book.image %>" class="card-img-top card_img" alt="Book Cover">
          <div class="card-body">
            <h5 class="card-title"><%=book.title%></h5>
            <p class="card-text">
              <%= book.author %><br>
              <%= book.genre %><br>
              <%= book.status %>
            </p>

            <a href="/books/<%= book.id %>" class="card-link">Card link</a>
            <a href="/books/<%= book.id %>/edit" class="card-link">Another link</a>

            <br><br>
            <div class="but">
              <form method="post" action="/books/<%= book.id %>?_method=DELETE">
                <button type="submit" class="btn btn-danger btn-delete">Delete</button>
              </form>
            </div>
          </div>
        </div>
        
    
    <%}%>
  </div>
    
  
    <a href="http://localhost:8080/books/new" class="floating-create-btn">
      <span class="plus-icon">+</span>
      <span class="btn-text">Add New Book</span>
<   /a>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
  </body>
</html>

